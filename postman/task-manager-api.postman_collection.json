{
  "info": {
    "_postman_id": "task-manager-api-collection",
    "name": "Task Manager API",
    "description": "RESTful API for managing tasks, built with Node.js and Express. Persists data to task.json. See README.md for full setup instructions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Get all tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"]
        },
        "description": "Returns the full list of tasks persisted in task.json."
      },
      "response": [
        {
          "name": "200 OK",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Set up environment\",\n    \"description\": \"Install Node.js, npm, and git\",\n    \"completed\": true\n  },\n  {\n    \"id\": 2,\n    \"title\": \"Create a new project\",\n    \"description\": \"Create a new project using the Express application generator\",\n    \"completed\": true\n  }\n]"
        }
      ]
    },
    {
      "name": "Get task by ID",
      "request": {

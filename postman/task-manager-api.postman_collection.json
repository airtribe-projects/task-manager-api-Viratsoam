    {
      "name": "Create task with invalid body",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Valid Title\",\n  \"description\": \"Valid Description\",\n  \"completed\": \"false\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"]
        },
        "description": "Demonstrates validation: completed must be a boolean, not a string. Returns 400."
      },
      "response": [
        {
          "name": "400 Bad Request (wrong type)",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",

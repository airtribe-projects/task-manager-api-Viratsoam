        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        },
        "description": "Returns a single task matching the given numeric id. Returns 400 for non-numeric ids and 404 when the task does not exist."
      },
      "response": [
        {
          "name": "200 OK",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/1",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "1"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"id\": 1,\n  \"title\": \"Set up environment\",\n  \"description\": \"Install Node.js, npm, and git\",\n  \"completed\": true\n}"
        },
        {
          "name": "404 Not Found",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/999",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "999"]
            }
          },
          "status": "Not Found",
          "code": 404,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"error\": \"Task not found\"\n}"
        },
        {
          "name": "400 Bad Request (non-numeric id)",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/abc",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "abc"]
            }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"error\": \"Invalid task ID: must be a number\"\n}"
        }
      ]
    },
    {
      "name": "Create a task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"completed\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"]
        },
        "description": "Creates a new task. The id is assigned automatically as max(existing ids) + 1. Returns 201 on success and 400 on validation failure (missing fields, wrong types, or empty strings)."
      },
      "response": [
        {
          "name": "201 Created",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"completed\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            }
          },
          "status": "Created",
          "code": 201,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"id\": 29,\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"completed\": false\n}"
        },
        {
          "name": "400 Bad Request (missing fields)",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Task\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"error\": \"title, description, and completed are required\"\n}"
        }
      ]
    },
    {
      "name": "Update a task",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Set up environment (updated)\",\n  \"description\": \"Install Node.js, npm, and git\",\n  \"completed\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        },
        "description": "Replaces the task with the given id. The request body must satisfy the same validation rules as POST. Returns 200 on success, 400 on validation failure, 404 if the task does not exist."
      },
      "response": [
        {
          "name": "200 OK",
          "originalRequest": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Set up environment (updated)\",\n  \"description\": \"Install Node.js, npm, and git\",\n  \"completed\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/1",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "1"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"id\": 1,\n  \"title\": \"Set up environment (updated)\",\n  \"description\": \"Install Node.js, npm, and git\",\n  \"completed\": true\n}"

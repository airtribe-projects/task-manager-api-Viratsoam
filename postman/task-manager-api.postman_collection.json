      "name": "Delete a task",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/tasks/1",
          "host": ["{{baseUrl}}"],
          "path": ["tasks", "1"]
        },
        "description": "Removes the task with the given id and returns the deleted record. Returns 404 if the task does not exist."
      },
      "response": [

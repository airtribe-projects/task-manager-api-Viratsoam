            },
            "url": {
              "raw": "{{baseUrl}}/tasks/999",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "999"]
            }
          },
          "status": "Not Found",
          "code": 404,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"error\": \"Task not found\"\n}"
        }
      ]
    },
